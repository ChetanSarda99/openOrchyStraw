#!/usr/bin/env bash
# orchystraw — Multi-agent AI orchestration CLI
# The single entry point for all projects.
#
# Two-root architecture:
#   ORCH_ROOT   = where orchystraw code lives (modules, templates, orchestrator)
#   PROJECT_ROOT = the target project (agents.conf, prompts, .orchystraw state)

set -uo pipefail

# ── Require bash 5+ ─────────────────────────────────────────────────────
if [[ "${BASH_VERSINFO[0]}" -lt 5 ]]; then
    echo "ERROR: orchystraw requires bash 5.0+ (you have $BASH_VERSION)"
    echo ""
    echo "Install:"
    echo "  macOS:  brew install bash"
    echo "  Ubuntu: sudo apt-get install -y bash"
    echo "  Then:   exec bash \$0 \"\$@\""
    exit 1
fi

# ── Resolve ORCH_ROOT from script location ──────────────────────────────
ORCH_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export ORCH_ROOT

# ── Find bash 5 for subprocesses ────────────────────────────────────────
ORCH_BASH="$BASH"  # use the same bash that's running us (already verified 5+)
export ORCH_BASH

# ── Source project registry ─────────────────────────────────────────────
if [[ -f "$ORCH_ROOT/src/core/project-registry.sh" ]]; then
    source "$ORCH_ROOT/src/core/project-registry.sh"
fi

# ── Source quality scorer ───────────────────────────────────────────────
if [[ -f "$ORCH_ROOT/src/core/quality-scorer.sh" ]]; then
    source "$ORCH_ROOT/src/core/quality-scorer.sh"
fi

# ── Helpers ─────────────────────────────────────────────────────────────

resolve_project_root() {
    local path="$1"
    # Resolve to absolute path
    if [[ ! "$path" = /* ]]; then
        path="$(cd "$path" 2>/dev/null && pwd)" || {
            echo "ERROR: Cannot resolve path: $1"
            exit 1
        }
    fi
    # Strip trailing slash
    path="${path%/}"
    echo "$path"
}

validate_project() {
    local project="$1"
    if [[ -f "$project/agents.conf" ]]; then
        return 0
    elif [[ -f "$project/scripts/agents.conf" ]]; then
        return 0
    else
        echo "ERROR: No agents.conf found in $project or $project/scripts/"
        echo "  Run 'orchystraw init $project' to set up a new project."
        return 1
    fi
}

usage() {
    echo "orchystraw — Multi-agent AI orchestration CLI"
    echo ""
    echo "Usage:"
    echo "  orchystraw run <project-path...> [--cycles N] [--dry-run] [--review] [--smart-models] [--budget N]"
    echo "  orchystraw run --all [--cycles N]      Run all registered projects"
    echo "  orchystraw run --all --parallel [N]    Run projects concurrently (max N)"
    echo "  orchystraw run                         Interactive project picker"
    echo "  orchystraw app                         Launch dashboard"
    echo "  orchystraw update                      Pull latest version"
    echo "  orchystraw add <project-path...>       Register project(s) without running"
    echo "  orchystraw scan [dir]                  Auto-discover projects (default: ~/Projects)"
    echo "  orchystraw remove <project-path...>    Unregister project(s)"
    echo "  orchystraw status [project-path]       Show project status (or all registered)"
    echo "  orchystraw init <target-dir> [--template saas|api|content] [--name NAME]"
    echo "  orchystraw list                        List all registered projects"
    echo "  orchystraw metrics <project-path>      Show performance data"
    echo "  orchystraw decisions <project-path> [--actor X] [--type Y] [--last N]"
    echo "  orchystraw prompt-audit [project]        Audit prompt token sizes + optimization"
    echo "  orchystraw benchmark [project|--all]    Performance metrics across projects"
    echo "  orchystraw dashboard                   Generate cross-project HTML dashboard"
    echo "  orchystraw doctor                      Validate environment"
    echo ""
    echo "Architecture:"
    echo "  ORCH_ROOT    = $ORCH_ROOT"
    echo "  PROJECT_ROOT = <first positional arg>"
    echo ""
    echo ""
    echo "Options:"
    echo "  --smart-models     Enable intelligent model selection (opus/sonnet/haiku per task)"
    echo "  --budget N         Daily budget in USD (default: 50)"
    echo "  --parallel [N]     Run multiple projects concurrently (default: unlimited)"
    echo "  --auto-improve     Karpathy-style: run cycles, measure quality, revert regressions"
    echo "  --improve-iterations N  Max improvement iterations (default: 10)"
    echo "  --review           Approve each commit before it lands"
    echo "  --telegram         Send notifications via Telegram"
    echo "  --sync-state       Sync state across machines"
    echo ""
    echo "Examples:"
    echo "  orchystraw run ~/Projects/Klaro --cycles 5"
    echo "  orchystraw run ~/Projects/Klaro ~/Projects/AIVA --cycles 3 --smart-models"
    echo "  orchystraw run --all --cycles 1 --dry-run"
    echo "  orchystraw add ~/Projects/Klaro ~/Projects/AIVA ~/Projects/Momentum"
    echo "  orchystraw init ~/Projects/NewApp --template saas --name NewApp"
    echo "  orchystraw doctor"
}

# ── Subcommand: run ─────────────────────────────────────────────────────

_run_single_project() {
    local project_path="$1"
    shift
    local -a args=("$@")

    PROJECT_ROOT="$project_path"
    export PROJECT_ROOT

    validate_project "$PROJECT_ROOT" || return 1

    # Auto-register in project registry
    if [[ "$(type -t orch_registry_register)" == "function" ]]; then
        orch_registry_register "$PROJECT_ROOT" "$(basename "$PROJECT_ROOT")"
    fi

    # Update last run timestamp
    if [[ "$(type -t orch_registry_update_last_run)" == "function" ]]; then
        orch_registry_update_last_run "$PROJECT_ROOT"
    fi

    echo "╔══════════════════════════════════════════════════╗"
    echo "║  orchystraw — run                               ║"
    echo "║  ORCH_ROOT:    $ORCH_ROOT"
    echo "║  PROJECT_ROOT: $PROJECT_ROOT"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""

    "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" "${args[@]}"
    return $?
}

cmd_run() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw run <project-path...> [--cycles N] [--dry-run] [--review] [--smart-models]"
        echo "       orchystraw run --all [--cycles N]"
        exit 1
    fi

    # Separate project paths from flags
    local -a project_paths=()
    local -a agent_args=("orchestrate")
    local cycles=""
    local run_all=false
    local parallel_max=0  # 0 = sequential, >0 = max concurrent

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)      run_all=true; shift ;;
            --cycles)   cycles="$2"; shift 2 ;;
            --dry-run)  agent_args+=("--dry-run"); shift ;;
            --review)   agent_args+=("--review"); shift ;;
            --telegram) agent_args+=("--telegram"); shift ;;
            --sync-state) agent_args+=("--sync-state"); shift ;;
            --cost-limit) agent_args+=("--cost-limit" "$2"); shift 2 ;;
            --max-parallel) agent_args+=("--max-parallel" "$2"); shift 2 ;;
            --watch)    agent_args+=("--watch"); shift ;;
            --smart-models) agent_args+=("--smart-models"); shift ;;
            --force) agent_args+=("--force"); shift ;;
            --auto-improve) agent_args+=("--auto-improve"); shift ;;
            --improve-iterations) agent_args+=("--improve-iterations" "$2"); shift 2 ;;
            --budget)   export ORCH_DAILY_BUDGET="$2"; shift 2 ;;
            --parallel)
                if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                    parallel_max="$2"; shift 2
                else
                    parallel_max=999; shift  # unlimited
                fi
                ;;
            -*)         agent_args+=("$1"); shift ;;
            *)
                # Treat non-flag args as project paths
                local resolved
                resolved="$(resolve_project_root "$1")" || exit 1
                project_paths+=("$resolved")
                shift
                ;;
        esac
    done
    [[ -n "$cycles" ]] && agent_args+=("$cycles")

    # --all: run every registered project
    if [[ "$run_all" == true ]]; then
        if [[ "$(type -t orch_registry_get_all_paths)" != "function" ]]; then
            echo "ERROR: Registry module not available."
            exit 1
        fi
        while IFS= read -r p; do
            [[ -n "$p" ]] && project_paths+=("$p")
        done < <(orch_registry_get_all_paths)
        if [[ ${#project_paths[@]} -eq 0 ]]; then
            echo "No projects registered. Add projects first:"
            echo "  orchystraw add ~/Projects/MyApp"
            exit 1
        fi
    fi

    # No projects specified — interactive picker
    if [[ ${#project_paths[@]} -eq 0 ]]; then
        if [[ "$(type -t orch_registry_get_all_paths)" != "function" ]] || \
           [[ ! -s "$ORCH_REGISTRY_FILE" ]]; then
            echo "No projects registered."
            echo "  orchystraw scan ~/Projects    # discover projects"
            echo "  orchystraw add ~/Projects/X   # register manually"
            exit 1
        fi

        # Build project list
        local -a all_paths=()
        local -a all_names=()
        local -a all_info=()
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local p n lr
            p=$(echo "$line" | grep -o '"path":"[^"]*"' | head -1 | cut -d'"' -f4)
            n=$(echo "$line" | grep -o '"name":"[^"]*"' | head -1 | cut -d'"' -f4)
            lr=$(echo "$line" | grep -o '"last_run":"[^"]*"' | head -1 | cut -d'"' -f4)
            [[ -z "$p" ]] && continue
            local agents="-"
            if [[ -f "$p/agents.conf" ]]; then
                agents=$(grep -cE '^[^#[:space:]]' "$p/agents.conf" 2>/dev/null || echo "?")
            fi
            all_paths+=("$p")
            all_names+=("$n")
            all_info+=("${agents} agents, last: ${lr:-never}")
        done < "$ORCH_REGISTRY_FILE"

        if [[ ${#all_paths[@]} -eq 0 ]]; then
            echo "No projects registered. Run: orchystraw scan ~/Projects"
            exit 1
        fi

        echo "╔══════════════════════════════════════════════════╗"
        echo "║  Select project(s) to run                       ║"
        echo "╚══════════════════════════════════════════════════╝"
        echo ""
        local i
        for i in "${!all_paths[@]}"; do
            printf "  [%d] %-20s (%s)\n" "$((i + 1))" "${all_names[$i]}" "${all_info[$i]}"
        done
        echo ""
        echo "  [a] All projects"
        echo ""
        printf "Enter choice (1-%d, comma-separated, or 'a'): " "${#all_paths[@]}"
        read -r choice

        if [[ "$choice" == "a" || "$choice" == "A" || "$choice" == "all" ]]; then
            project_paths=("${all_paths[@]}")
        elif [[ -n "$choice" ]]; then
            IFS=',' read -ra selections <<< "$choice"
            for sel in "${selections[@]}"; do
                sel=$(echo "$sel" | tr -d ' ')
                if [[ "$sel" =~ ^[0-9]+$ ]] && [[ "$sel" -ge 1 ]] && [[ "$sel" -le ${#all_paths[@]} ]]; then
                    project_paths+=("${all_paths[$((sel - 1))]}")
                else
                    echo "Invalid selection: $sel"
                fi
            done
        fi

        if [[ ${#project_paths[@]} -eq 0 ]]; then
            echo "No projects selected."
            exit 0
        fi
        echo ""
    fi

    # Single project — exec directly (replaces this process)
    if [[ ${#project_paths[@]} -eq 1 ]]; then
        PROJECT_ROOT="${project_paths[0]}"
        export PROJECT_ROOT
        validate_project "$PROJECT_ROOT" || exit 1

        if [[ "$(type -t orch_registry_register)" == "function" ]]; then
            orch_registry_register "$PROJECT_ROOT" "$(basename "$PROJECT_ROOT")"
        fi
        if [[ "$(type -t orch_registry_update_last_run)" == "function" ]]; then
            orch_registry_update_last_run "$PROJECT_ROOT"
        fi

        echo "orchystraw — run"
        echo "  ORCH_ROOT:    $ORCH_ROOT"
        echo "  PROJECT_ROOT: $PROJECT_ROOT"
        echo ""

        exec "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" "${agent_args[@]}"
    fi

    # Multiple projects
    local total=${#project_paths[@]}
    local passed=0
    local failed=0
    local mode="sequential"
    [[ "$parallel_max" -gt 0 ]] && mode="parallel (max $parallel_max)"

    echo "╔══════════════════════════════════════════════════╗"
    echo "║  orchystraw — multi-project run ($total projects)     ║"
    echo "║  Mode: $mode"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""
    for p in "${project_paths[@]}"; do
        echo "  → $(basename "$p"): $p"
    done
    echo ""

    if [[ "$parallel_max" -gt 0 ]]; then
        # ── Parallel execution ──
        local -a pids=()
        local -a pid_projects=()
        local log_dir
        log_dir=$(mktemp -d)
        local running=0

        for p in "${project_paths[@]}"; do
            # Throttle: wait if at max concurrent
            while [[ "$running" -ge "$parallel_max" ]]; do
                # Wait for any child to finish
                for i in "${!pids[@]}"; do
                    if ! kill -0 "${pids[$i]}" 2>/dev/null; then
                        wait "${pids[$i]}" 2>/dev/null && passed=$((passed + 1)) || failed=$((failed + 1))
                        local done_name
                        done_name=$(basename "${pid_projects[$i]}")
                        echo "  ✓ $done_name finished"
                        unset 'pids[i]' 'pid_projects[i]'
                        running=$((running - 1))
                        break
                    fi
                done
                sleep 1
            done

            local proj_name
            proj_name=$(basename "$p")
            local proj_log="$log_dir/$proj_name.log"
            echo "  ⚡ Starting $proj_name (log: $proj_log)"

            _run_single_project "$p" "${agent_args[@]}" > "$proj_log" 2>&1 &
            pids+=($!)
            pid_projects+=("$p")
            running=$((running + 1))
        done

        # Wait for remaining
        for i in "${!pids[@]}"; do
            wait "${pids[$i]}" 2>/dev/null && passed=$((passed + 1)) || failed=$((failed + 1))
            local done_name
            done_name=$(basename "${pid_projects[$i]}")
            echo "  ✓ $done_name finished"
        done

        echo ""
        echo "  Logs: $log_dir/"
    else
        # ── Sequential execution ──
        for p in "${project_paths[@]}"; do
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "  [$((passed + failed + 1))/$total] $(basename "$p")"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

            if _run_single_project "$p" "${agent_args[@]}"; then
                passed=$((passed + 1))
            else
                failed=$((failed + 1))
                echo "  ⚠ $(basename "$p") failed (continuing with remaining projects)"
            fi
            echo ""
        done
    fi

    echo "╔══════════════════════════════════════════════════╗"
    echo "║  Multi-project run complete                     ║"
    echo "║  Passed: $passed  Failed: $failed  Total: $total               ║"
    echo "╚══════════════════════════════════════════════════╝"
}

# ── Subcommand: status ──────────────────────────────────────────────────

cmd_status() {
    if [[ $# -ge 1 ]]; then
        # Single project status
        PROJECT_ROOT="$(resolve_project_root "$1")"
        export PROJECT_ROOT
        validate_project "$PROJECT_ROOT" || exit 1

        echo "orchystraw — status"
        echo "  ORCH_ROOT:    $ORCH_ROOT"
        echo "  PROJECT_ROOT: $PROJECT_ROOT"
        echo ""

        exec "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" status
    else
        # All registered projects
        if [[ "$(type -t orch_registry_status)" == "function" ]]; then
            orch_registry_status
        else
            echo "No project specified and registry not available."
            echo "Usage: orchystraw status <project-path>"
        fi
    fi
}

# ── Subcommand: init ────────────────────────────────────────────────────

cmd_init() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw init <target-dir> [--template saas|api|content] [--name NAME]"
        exit 1
    fi

    local target=""
    local template="saas"
    local name=""
    local -a passthrough=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --template|-t) template="$2"; shift 2 ;;
            --name|-n)     name="$2"; shift 2 ;;
            --list|-l)     passthrough+=("--list"); shift ;;
            -*)            passthrough+=("$1"); shift ;;
            *)
                if [[ -z "$target" ]]; then
                    target="$1"
                else
                    passthrough+=("$1")
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$target" && ${#passthrough[@]} -eq 0 ]]; then
        echo "Usage: orchystraw init <target-dir> [--template saas|api|content] [--name NAME]"
        exit 1
    fi

    # For --list, delegate directly
    if [[ " ${passthrough[*]} " == *" --list "* ]]; then
        PROJECT_ROOT="${target:-$ORCH_ROOT}"
        export PROJECT_ROOT
        exec "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" init --list
    fi

    # Resolve target to absolute
    if [[ -n "$target" && ! "$target" = /* ]]; then
        target="$(pwd)/$target"
    fi

    # Set PROJECT_ROOT to ORCH_ROOT for init (it reads templates from there)
    PROJECT_ROOT="$ORCH_ROOT"
    export PROJECT_ROOT

    local -a init_args=("init")
    [[ -n "$template" ]] && init_args+=("--template" "$template")
    [[ -n "$name" ]] && init_args+=("--name" "$name")
    [[ -n "$target" ]] && init_args+=("$target")
    init_args+=("${passthrough[@]}")

    exec "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" "${init_args[@]}"
}

# ── Subcommand: add ─────────────────────────────────────────────────────

cmd_add() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw add <project-path...>"
        echo ""
        echo "Register one or more projects without running them."
        echo "Projects must have an agents.conf file."
        echo ""
        echo "Examples:"
        echo "  orchystraw add ~/Projects/Klaro"
        echo "  orchystraw add ~/Projects/Klaro ~/Projects/AIVA ~/Projects/Momentum"
        exit 1
    fi

    if [[ "$(type -t orch_registry_register)" != "function" ]]; then
        echo "ERROR: Registry module not available."
        exit 1
    fi

    local added=0
    local skipped=0

    for path_arg in "$@"; do
        local project
        project="$(resolve_project_root "$path_arg")" || {
            echo "  ✗ $path_arg — cannot resolve path"
            skipped=$((skipped + 1))
            continue
        }

        if ! validate_project "$project" 2>/dev/null; then
            echo "  ✗ $(basename "$project") — no agents.conf found"
            skipped=$((skipped + 1))
            continue
        fi

        orch_registry_register "$project" "$(basename "$project")"
        echo "  ✓ $(basename "$project") — registered ($project)"
        added=$((added + 1))
    done

    echo ""
    echo "Added: $added  Skipped: $skipped"
    if [[ "$added" -gt 0 ]]; then
        echo ""
        echo "Run them: orchystraw run --all --cycles 1 --dry-run"
    fi
}

# ── Subcommand: list ────────────────────────────────────────────────────

cmd_list() {
    if [[ "$(type -t orch_registry_list)" == "function" ]]; then
        orch_registry_list
    else
        echo "Registry module not available."
        exit 1
    fi
}

# ── Subcommand: metrics ────────────────────────────────────────────────

cmd_metrics() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw metrics <project-path>"
        exit 1
    fi

    local project
    project="$(resolve_project_root "$1")"

    echo "orchystraw — metrics for $(basename "$project")"
    echo "  Path: $project"
    echo ""

    # Metrics from .orchystraw/
    local metrics_file="$project/.orchystraw/metrics.jsonl"
    local audit_file="$project/.orchystraw/audit.jsonl"
    local router_state="$project/.orchystraw/router-state.txt"
    local quality_file="$project/.orchystraw/quality-scores.jsonl"

    if [[ -f "$audit_file" ]]; then
        local total_inv=0 total_tok=0
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            total_inv=$((total_inv + 1))
            local tok
            tok=$(echo "$line" | grep -o '"tokens_est":[0-9]*' | grep -o '[0-9]*' || echo 0)
            total_tok=$((total_tok + tok))
        done < "$audit_file"
        echo "  Audit log:"
        echo "    Total invocations: $total_inv"
        echo "    Total tokens:      $total_tok"
        echo ""
    fi

    if [[ -f "$metrics_file" ]]; then
        local metric_count
        metric_count=$(wc -l < "$metrics_file" | tr -d ' ')
        echo "  Metrics entries: $metric_count"
        echo "  Recent:"
        tail -5 "$metrics_file" | sed 's/^/    /'
        echo ""
    fi

    if [[ -f "$router_state" ]]; then
        echo "  Router state:"
        cat "$router_state" | sed 's/^/    /'
        echo ""
    fi

    if [[ -f "$quality_file" ]]; then
        local score_count
        score_count=$(wc -l < "$quality_file" | tr -d ' ')
        echo "  Quality scores: $score_count entries"
        echo "  Recent:"
        tail -5 "$quality_file" | sed 's/^/    /'
        echo ""
    fi

    if [[ ! -f "$audit_file" && ! -f "$metrics_file" && ! -f "$quality_file" ]]; then
        echo "  No metrics data found. Run 'orchystraw run $project' first."
    fi
}

# ── Subcommand: decisions ──────────────────────────────────────────────

cmd_decisions() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw decisions <project-path> [--actor X] [--type Y] [--last N]"
        exit 1
    fi

    PROJECT_ROOT="$(resolve_project_root "$1")"
    shift
    export PROJECT_ROOT

    exec "$ORCH_BASH" "$ORCH_ROOT/scripts/auto-agent.sh" decisions "$@"
}

# ── Subcommand: dashboard ──────────────────────────────────────────────

cmd_dashboard() {
    if [[ -f "$ORCH_ROOT/scripts/cross-project-dashboard.sh" ]]; then
        "$ORCH_BASH" "$ORCH_ROOT/scripts/cross-project-dashboard.sh"
    else
        echo "ERROR: cross-project-dashboard.sh not found"
        exit 1
    fi
}

# ── Subcommand: prompt-audit ────────────────────────────────────────────

cmd_prompt_audit() {
    local project="${1:-.}"
    project="$(resolve_project_root "$project")"

    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  orchystraw prompt-audit — $(basename "$project")"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""

    local conf="$project/agents.conf"
    [[ ! -f "$conf" ]] && conf="$project/scripts/agents.conf"
    if [[ ! -f "$conf" ]]; then
        echo "  No agents.conf found in $project"
        exit 1
    fi

    printf "  %-20s %7s %7s %5s  %s\n" "AGENT" "CHARS" "~TOKENS" "LINES" "OPTIMIZATION"
    echo "  ────────────────────────────────────────────────────────────────"

    local total_chars=0 total_tokens=0
    local -a large_prompts=()

    while IFS='|' read -r id prompt_path ownership interval label; do
        [[ "$id" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${id// /}" ]] && continue
        id=$(echo "$id" | xargs)
        prompt_path=$(echo "$prompt_path" | xargs)

        local full_path="$project/$prompt_path"
        if [[ ! -f "$full_path" ]]; then
            printf "  %-20s %7s %7s %5s  %s\n" "$id" "-" "-" "-" "MISSING: $prompt_path"
            continue
        fi

        local chars lines tokens opt=""
        chars=$(wc -c < "$full_path" | tr -d ' ')
        lines=$(wc -l < "$full_path" | tr -d ' ')
        tokens=$((chars / 4))

        total_chars=$((total_chars + chars))
        total_tokens=$((total_tokens + tokens))

        # Optimization suggestions
        if [[ "$tokens" -gt 4000 ]]; then
            opt="LARGE — consider splitting or compressing"
            large_prompts+=("$id")
        elif [[ "$tokens" -gt 3000 ]]; then
            opt="moderate — review for redundancy"
        else
            opt="ok"
        fi

        # Check for common bloat patterns
        local dupes=0
        dupes=$(grep -c "IMPORTANT\|NOTE:\|REMEMBER\|DO NOT\|NEVER\|ALWAYS\|MUST" "$full_path" 2>/dev/null || echo 0)
        if [[ "$dupes" -gt 10 ]]; then
            opt="$opt (${dupes} directive keywords)"
        fi

        printf "  %-20s %7d %7d %5d  %s\n" "$id" "$chars" "$tokens" "$lines" "$opt"
    done < "$conf"

    echo "  ────────────────────────────────────────────────────────────────"
    printf "  %-20s %7d %7d\n" "TOTAL" "$total_chars" "$total_tokens"

    # Shared context size
    local shared_ctx="$project/prompts/00-shared-context/context.md"
    if [[ -f "$shared_ctx" ]]; then
        local sc_chars sc_tokens
        sc_chars=$(wc -c < "$shared_ctx" | tr -d ' ')
        sc_tokens=$((sc_chars / 4))
        echo ""
        printf "  Shared context:    %7d chars  ~%d tokens\n" "$sc_chars" "$sc_tokens"
    fi

    # Cost estimate
    echo ""
    echo "  ── Cost Estimate (per full cycle, all agents) ──"
    local opus_cost sonnet_cost haiku_cost
    opus_cost=$(( total_tokens * 15 / 1000000 ))    # $15/M
    sonnet_cost=$(( total_tokens * 3 / 1000000 ))    # $3/M
    haiku_cost=$(( total_tokens * 1 / 4000000 ))     # $0.25/M
    printf "  All Opus:   ~\$%d.%02d per cycle\n" "$((opus_cost))" "$(( (total_tokens * 1500 / 1000000) % 100 ))"
    printf "  All Sonnet: ~\$%d.%02d per cycle\n" "$((sonnet_cost))" "$(( (total_tokens * 300 / 1000000) % 100 ))"
    printf "  Mixed (smart-models): ~30-60%% savings vs all-opus\n"

    if [[ ${#large_prompts[@]} -gt 0 ]]; then
        echo ""
        echo "  ── Optimization Targets ──"
        for lp in "${large_prompts[@]}"; do
            echo "  • $lp — over 4000 tokens, candidate for compression"
        done
        echo ""
        echo "  Tip: Use prompt-compression.sh tiered loading (stable/dynamic/reference)"
    fi
}

# ── Subcommand: benchmark ──────────────────────────────────────────────

cmd_benchmark() {
    local project="${1:-}"
    local show_all=false

    if [[ "$project" == "--all" || -z "$project" ]]; then
        show_all=true
    fi

    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  orchystraw benchmark                                      ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""

    local -a paths=()

    if [[ "$show_all" == true ]]; then
        if [[ "$(type -t orch_registry_get_all_paths)" == "function" ]]; then
            while IFS= read -r p; do
                [[ -n "$p" ]] && paths+=("$p")
            done < <(orch_registry_get_all_paths)
        fi
        if [[ ${#paths[@]} -eq 0 ]]; then
            echo "No projects registered. Run: orchystraw scan ~/Projects"
            exit 1
        fi
    else
        paths+=("$(resolve_project_root "$project")")
    fi

    # Header
    printf "  %-18s %6s %8s %8s %10s %8s %6s\n" \
        "PROJECT" "AGENTS" "CYCLES" "COMMITS" "TOKENS" "COST" "SCORE"
    echo "  ──────────────────────────────────────────────────────────────"

    local total_cycles=0 total_commits=0 total_tokens=0 total_cost_cents=0

    for p in "${paths[@]}"; do
        local name
        name=$(basename "$p")
        local agents="-"
        local cycles=0 commits=0 tokens=0 cost_cents=0 avg_score="-"

        # Agent count
        if [[ -f "$p/agents.conf" ]]; then
            agents=$(grep -cE '^[^#[:space:]]' "$p/agents.conf" 2>/dev/null || echo "0")
        fi

        # Audit data
        local audit="$p/.orchystraw/audit.jsonl"
        if [[ -f "$audit" ]]; then
            cycles=$(wc -l < "$audit" | tr -d ' ')

            # Parse tokens and commits
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                local tok=""
                if [[ "$line" =~ \"tokens_est\":([0-9]+) ]]; then
                    tok="${BASH_REMATCH[1]}"
                    tokens=$((tokens + tok))
                fi
                if [[ "$line" =~ \"commits\":([0-9]+) ]]; then
                    commits=$((commits + BASH_REMATCH[1]))
                fi
            done < "$audit"
        fi

        # Cost log
        local cost_log="$p/.orchystraw/cost-log.jsonl"
        if [[ -f "$cost_log" ]]; then
            while IFS= read -r line; do
                local t="" m=""
                if [[ "$line" =~ \"tokens\":([0-9]+) ]]; then t="${BASH_REMATCH[1]}"; fi
                if [[ "$line" =~ \"model\":\"([^\"]+)\" ]]; then m="${BASH_REMATCH[1]}"; fi
                [[ -z "$t" ]] && continue
                case "${m:-sonnet}" in
                    opus)   cost_cents=$((cost_cents + t * 1500 / 1000000)) ;;
                    sonnet) cost_cents=$((cost_cents + t * 300 / 1000000)) ;;
                    haiku)  cost_cents=$((cost_cents + t * 25 / 1000000)) ;;
                esac
            done < "$cost_log"
        fi

        # Quality scores
        local quality="$p/.orchystraw/quality-scores.jsonl"
        if [[ -f "$quality" ]]; then
            local q_total=0 q_count=0
            while IFS= read -r line; do
                if [[ "$line" =~ \"score\":([0-9]+) ]]; then
                    q_total=$((q_total + BASH_REMATCH[1]))
                    q_count=$((q_count + 1))
                fi
            done < "$quality"
            [[ "$q_count" -gt 0 ]] && avg_score=$((q_total / q_count))
        fi

        # Git commits (actual)
        if [[ -d "$p/.git" ]]; then
            local git_commits
            git_commits=$(git -C "$p" rev-list --count HEAD 2>/dev/null || echo "0")
            [[ "$commits" -eq 0 ]] && commits="$git_commits"
        fi

        local cost_display
        cost_display=$(printf '$%d.%02d' "$((cost_cents / 100))" "$((cost_cents % 100))")
        [[ "$cost_cents" -eq 0 ]] && cost_display="-"

        local token_display="$tokens"
        if [[ "$tokens" -gt 1000000 ]]; then
            token_display="$(( tokens / 1000000 ))M"
        elif [[ "$tokens" -gt 1000 ]]; then
            token_display="$(( tokens / 1000 ))K"
        fi
        [[ "$tokens" -eq 0 ]] && token_display="-"

        printf "  %-18s %6s %8s %8s %10s %8s %6s\n" \
            "${name:0:18}" "$agents" "$cycles" "$commits" "$token_display" "$cost_display" "$avg_score"

        total_cycles=$((total_cycles + cycles))
        total_commits=$((total_commits + commits))
        total_tokens=$((total_tokens + tokens))
        total_cost_cents=$((total_cost_cents + cost_cents))
    done

    echo "  ──────────────────────────────────────────────────────────────"
    local total_cost_display
    total_cost_display=$(printf '$%d.%02d' "$((total_cost_cents / 100))" "$((total_cost_cents % 100))")
    local total_tok_display="$total_tokens"
    if [[ "$total_tokens" -gt 1000000 ]]; then
        total_tok_display="$(( total_tokens / 1000000 ))M"
    elif [[ "$total_tokens" -gt 1000 ]]; then
        total_tok_display="$(( total_tokens / 1000 ))K"
    fi
    printf "  %-18s %6s %8s %8s %10s %8s\n" \
        "TOTAL" "${#paths[@]} proj" "$total_cycles" "$total_commits" "$total_tok_display" "$total_cost_display"

    echo ""
    echo "  Run cycles to generate data: orchystraw run --all --cycles 1 --dry-run"
}

# ── Subcommand: doctor ─────────────────────────────────────────────────

cmd_doctor() {
    echo "orchystraw doctor — environment check"
    echo ""

    local issues=0

    # Bash 5+
    local bash_ver
    bash_ver=$("$ORCH_BASH" --version | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
    local bash_major="${bash_ver%%.*}"
    if [[ "$bash_major" -ge 5 ]]; then
        echo "  [OK] bash $bash_ver (>= 5.0)"
    else
        echo "  [FAIL] bash $bash_ver (need 5.0+)"
        issues=$((issues + 1))
    fi

    # Claude CLI
    if command -v claude &>/dev/null; then
        local claude_ver
        claude_ver=$(claude --version 2>/dev/null | head -1 || echo "unknown")
        echo "  [OK] claude CLI ($claude_ver)"
    else
        echo "  [FAIL] claude CLI not found"
        issues=$((issues + 1))
    fi

    # Git
    if command -v git &>/dev/null; then
        local git_ver
        git_ver=$(git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")
        echo "  [OK] git $git_ver"
    else
        echo "  [FAIL] git not found"
        issues=$((issues + 1))
    fi

    # gh CLI
    if command -v gh &>/dev/null; then
        echo "  [OK] gh CLI"
    else
        echo "  [WARN] gh CLI not found (optional — needed for GitHub integration)"
    fi

    # shellcheck
    if command -v shellcheck &>/dev/null; then
        echo "  [OK] shellcheck"
    else
        echo "  [WARN] shellcheck not found (optional — used by quality scorer)"
    fi

    # ORCH_ROOT structure
    echo ""
    echo "  ORCH_ROOT: $ORCH_ROOT"
    if [[ -f "$ORCH_ROOT/scripts/auto-agent.sh" ]]; then
        echo "  [OK] scripts/auto-agent.sh"
    else
        echo "  [FAIL] scripts/auto-agent.sh missing"
        issues=$((issues + 1))
    fi

    if [[ -d "$ORCH_ROOT/src/core" ]]; then
        local mod_count
        mod_count=$(ls "$ORCH_ROOT/src/core/"*.sh 2>/dev/null | wc -l | tr -d ' ')
        echo "  [OK] src/core/ ($mod_count modules)"
    else
        echo "  [FAIL] src/core/ missing"
        issues=$((issues + 1))
    fi

    if [[ -d "$ORCH_ROOT/template" ]]; then
        local tpl_count
        tpl_count=$(ls -d "$ORCH_ROOT/template/"*/ 2>/dev/null | wc -l | tr -d ' ')
        echo "  [OK] template/ ($tpl_count templates)"
    else
        echo "  [WARN] template/ missing"
    fi

    # Registry
    echo ""
    if [[ -d "$HOME/.orchystraw" ]]; then
        echo "  [OK] ~/.orchystraw/ exists"
        if [[ -f "$HOME/.orchystraw/registry.jsonl" ]]; then
            local reg_count
            reg_count=$(wc -l < "$HOME/.orchystraw/registry.jsonl" | tr -d ' ')
            echo "  [OK] registry.jsonl ($reg_count projects)"
        else
            echo "  [INFO] No projects registered yet"
        fi
    else
        echo "  [INFO] ~/.orchystraw/ not created yet (will be created on first run)"
    fi

    echo ""
    if [[ "$issues" -eq 0 ]]; then
        echo "  All checks passed."
    else
        echo "  $issues issue(s) found."
    fi
}

# ── Subcommand: app ─────────────────────────────────────────────────────

cmd_app() {
    if ! command -v node &>/dev/null; then
        echo "ERROR: Node.js required. Install: brew install node"
        exit 1
    fi

    local app_dir="$ORCH_ROOT/app"

    # Build frontend on first run
    if [[ ! -d "$app_dir/dist" ]]; then
        echo "First run — building dashboard..."
        if [[ ! -d "$app_dir/node_modules" ]]; then
            (cd "$app_dir" && npm install --silent) || { echo "ERROR: npm install failed"; exit 1; }
        fi
        (cd "$app_dir" && npx vite build --mode production) || { echo "ERROR: build failed"; exit 1; }
    fi

    # Host/port from config.env or defaults
    local host="${ORCH_HOST:-127.0.0.1}"
    local port="${ORCH_PORT:-4321}"

    ORCH_ROOT="$ORCH_ROOT" ORCH_HOST="$host" ORCH_PORT="$port" \
        node "$app_dir/server.js"
}

# ── Subcommand: update ──────────────────────────────────────────────────

cmd_update() {
    echo "Updating orchystraw..."

    local current_hash
    current_hash=$(git -C "$ORCH_ROOT" rev-parse --short HEAD 2>/dev/null)

    if ! git -C "$ORCH_ROOT" pull --ff-only 2>&1; then
        echo "  Could not fast-forward. You may have local changes."
        echo "  Run: cd $ORCH_ROOT && git stash && git pull && git stash pop"
        return 1
    fi

    local new_hash
    new_hash=$(git -C "$ORCH_ROOT" rev-parse --short HEAD 2>/dev/null)

    if [[ "$current_hash" == "$new_hash" ]]; then
        echo "  Already up to date ($current_hash)"
    else
        echo "  Updated: $current_hash → $new_hash"

        # Rebuild app frontend if it exists
        if [[ -d "$ORCH_ROOT/app/dist" ]]; then
            echo "  Rebuilding dashboard..."
            (cd "$ORCH_ROOT/app" && npm install --silent && npx vite build --mode production) 2>/dev/null
            echo "  Dashboard rebuilt"
        fi
    fi
}

# ── Subcommand: scan ────────────────────────────────────────────────────

cmd_scan() {
    local search_dir="${1:-$HOME/Projects}"

    if [[ ! -d "$search_dir" ]]; then
        echo "ERROR: Directory not found: $search_dir"
        exit 1
    fi

    echo "Scanning $search_dir for orchystraw-compatible projects..."
    echo ""

    local found=0
    local already=0
    local -a new_projects=()
    local -A seen_dirs=()

    for conf in "$search_dir"/*/agents.conf "$search_dir"/*/scripts/agents.conf; do
        [[ ! -f "$conf" ]] && continue

        local project_dir
        if [[ "$conf" == */scripts/agents.conf ]]; then
            project_dir="$(cd "$(dirname "$conf")/.." && pwd)"
        else
            project_dir="$(cd "$(dirname "$conf")" && pwd)"
        fi

        # Deduplicate (same project found via root and scripts/)
        [[ -n "${seen_dirs[$project_dir]+x}" ]] && continue
        seen_dirs["$project_dir"]=1

        found=$((found + 1))

        # Check if already registered
        if [[ -f "$ORCH_REGISTRY_FILE" ]] && grep -q "\"path\":\"$project_dir\"" "$ORCH_REGISTRY_FILE" 2>/dev/null; then
            echo "  ✓ $(basename "$project_dir") (already registered)"
            already=$((already + 1))
        else
            local agent_count
            agent_count=$(grep -cE '^[^#[:space:]]' "$conf" 2>/dev/null || echo "0")
            echo "  + $(basename "$project_dir") ($agent_count agents) — $project_dir"
            new_projects+=("$project_dir")
        fi
    done

    echo ""
    echo "Found: $found  Already registered: $already  New: ${#new_projects[@]}"

    if [[ ${#new_projects[@]} -gt 0 ]]; then
        echo ""
        echo "Register all new projects?"
        echo "  orchystraw add ${new_projects[*]}"
    fi
}

# ── Subcommand: remove ──────────────────────────────────────────────────

cmd_remove() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: orchystraw remove <project-path...>"
        exit 1
    fi

    if [[ "$(type -t orch_registry_remove)" != "function" ]]; then
        echo "ERROR: Registry module not available."
        exit 1
    fi

    for path_arg in "$@"; do
        local project
        project="$(resolve_project_root "$path_arg" 2>/dev/null)" || {
            echo "  ✗ $path_arg — cannot resolve path"
            continue
        }
        orch_registry_remove "$project"
        echo "  ✓ $(basename "$project") — removed from registry"
    done
}

# ── Main dispatch ───────────────────────────────────────────────────────

case "${1:-help}" in
    run)        shift; cmd_run "$@" ;;
    app)        shift; cmd_app "$@" ;;
    update)     shift; cmd_update "$@" ;;
    add)        shift; cmd_add "$@" ;;
    scan)       shift; cmd_scan "$@" ;;
    remove)     shift; cmd_remove "$@" ;;
    status)     shift; cmd_status "$@" ;;
    init)       shift; cmd_init "$@" ;;
    list)       shift; cmd_list "$@" ;;
    metrics)    shift; cmd_metrics "$@" ;;
    decisions)  shift; cmd_decisions "$@" ;;
    prompt-audit) shift; cmd_prompt_audit "$@" ;;
    benchmark)  shift; cmd_benchmark "$@" ;;
    dashboard)  shift; cmd_dashboard "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    help|--help|-h) usage ;;
    *)
        echo "Unknown command: $1"
        echo ""
        usage
        exit 1
        ;;
esac
