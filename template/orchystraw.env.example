# orchystraw.env — User configuration
# Copy to ~/.orchystraw/config.env or project-root/.env
#
# OrchyStraw reads this file at startup for API keys, CLI paths, and model preferences.

# ── AI Provider Keys ──────────────────────────────────────────────────
# Set the keys for providers you want to use. Leave blank to skip.

# Anthropic (Claude) — default provider
ANTHROPIC_API_KEY=
# Or use Claude Code CLI (no key needed if already authenticated):
# ORCH_CLI=claude

# OpenAI
OPENAI_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# ── Local LLM ─────────────────────────────────────────────────────────
# Use Ollama, llama.cpp, or any OpenAI-compatible local server

# Ollama (default local provider)
ORCH_LOCAL_PROVIDER=ollama
ORCH_LOCAL_URL=http://localhost:11434

# Model names (must be pulled: ollama pull llama3.3)
ORCH_LOCAL_MODEL=llama3.3
ORCH_LOCAL_MODEL_LARGE=qwen3:32b
ORCH_LOCAL_MODEL_SMALL=llama3.3

# Or use any OpenAI-compatible server:
# ORCH_LOCAL_PROVIDER=openai-compat
# ORCH_LOCAL_URL=http://localhost:8080/v1

# ── CLI Tool Paths ────────────────────────────────────────────────────
# Override if your CLI tools are in non-standard locations

# ORCH_CLI=claude                    # AI CLI (claude, aider, etc.)
# ORCH_CLI_OPENAI=openai             # OpenAI CLI
# ORCH_BASH=/opt/homebrew/bin/bash   # Bash 5+ path
# ORCH_GH=gh                         # GitHub CLI

# ── Default Model ─────────────────────────────────────────────────────
# Which model to use by default when --smart-models is not active
# Options: opus, sonnet, haiku, gpt4o, o3, o4-mini, gemini-pro, gemini-flash, local, local-large, local-small
ORCH_DEFAULT_MODEL=sonnet

# ── Budget ────────────────────────────────────────────────────────────
ORCH_DAILY_BUDGET=50

# ── Per-Agent Model Overrides ─────────────────────────────────────────
# Format: ORCH_MODEL_OVERRIDE_<AGENT_ID_UPPERCASE>=model
# Example: force backend to use opus, HR to use local
# ORCH_MODEL_OVERRIDE_06_BACKEND=opus
# ORCH_MODEL_OVERRIDE_13_HR=local
# ORCH_MODEL_OVERRIDE_08_PIXEL=haiku
